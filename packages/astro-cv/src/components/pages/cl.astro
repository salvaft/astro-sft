---
import { getEntry } from "astro:content";
import Sheet from "#/layouts/sheet.astro";
import { type CollectionEntry } from "astro:content";

const globResult = import.meta.glob("../*/letter/base.astro", { eager: true }) as Record<string, { default: any }>;

const flavors = Object.entries(globResult).map(([path, mod]) => {
    return {
        name: path.split("/").at(-3),
        component: mod.default,
    };
});

interface Props {
    entry: CollectionEntry<"cls">;
    flavor: string;
    standalone?: boolean;
}

const { entry, flavor, standalone } = Astro.props;
const Flavor = flavors.find((flav) => flav.name === flavor)?.component;
const personal = await getEntry("personal", "all");
---

<Sheet slug={entry.id} { standalone } >
    <Flavor {personal} {entry} />
</Sheet>
