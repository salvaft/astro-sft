---
interface Props {
  name: string;
  [key: string]: any;
}
const { name, ...rest } = Astro.props;
const iconGlob = import.meta.glob("../icons/*.icon.astro", { eager: true }) as Record<string, { default: any }>;
async function getIcon(name: string) {
  const entry = Object.entries(iconGlob).find(([path]) => {
    const filename = path.split("/").pop()?.split(".")[0];
    return filename === name;
  });
  if (!entry) throw new Error(`Icon ${name} not found`);
  return entry[1].default;
}
const IconElement = await getIcon(name);
---

<IconElement {...rest} />